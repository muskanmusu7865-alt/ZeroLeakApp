<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="20dp"
    android:background="@android:color/holo_green_light">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SafeGuard App"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginBottom="30dp"/>

    <Button
        android:id="@+id/btnFraudCall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🚨 Fraud Call Alert"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/btnSpamMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📩 Spam Message Alert"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/btnDataLeak"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔒 Data Leak Alert"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/btnPlayBuzzer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔊 Play Buzzer"/>

    <!-- 👇 Debug message ke liye TextView -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No Fraud Call Detected Yet"
        android:textSize="16sp"
        android:textColor="@android:color/holo_red_dark"
        android:layout_marginTop="30dp" />


</LinearLayout>
