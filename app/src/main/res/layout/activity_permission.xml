<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- App Logo -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/zeroleak_logo"
            android:contentDescription="ZeroLeak Logo"
            android:layout_marginTop="32dp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Allow Permissions"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/red_primary"
            android:layout_marginTop="16dp" />

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ZeroLeak needs these permissions to protect you from spam messages, OTP fraud, and unknown calls."
            android:textAlignment="center"
            android:textColor="@color/black"
            android:layout_marginTop="12dp" />

        <!-- Permission list -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Notification Access\n• SMS Read\n• Call Detection"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:layout_marginTop="12dp" />

        <!-- Allow Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAllowPermissions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Allow All Permissions"
            android:textColor="@color/white"
            android:layout_marginTop="28dp"
            android:backgroundTint="@color/red_primary"
            app:cornerRadius="24dp" />

    </LinearLayout>

</ScrollView>